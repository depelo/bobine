JWT_SECRET=cambiami_con_una_chiave_segreta
NODE_ENV=development

# === Server / SSL ===
# Porta HTTPS (443 in produzione, 3000 in sviluppo)
PORT=3000
# Cartella contenente rotoli.ujet.it-key.pem e rotoli.ujet.it-chain.pem
# Produzione: C:\Acme\certificati_ssl
# Sviluppo:   ./certificati/certsvil  (generati con mkcert)
SSL_CERT_DIR=./certificati/certsvil

# === Database servers ===
# In produzione su 163 GA e' localhost (Node gira sulla stessa macchina)
# In sviluppo via VPN puntare a 192.168.0.163
DB_SERVER_GA=192.168.0.163
DB_SERVER_PE=192.168.0.163

# === MRP/GB2 ===
DB_SERVER_MRP=192.168.0.163
DB_SERVER_UJET11=BCUBE2
DB_NAME_MRP=MRP
DB_UJET11=UJET11
DB_USER_MRP=sa
DB_PASSWORD_MRP=

# === Chiave crittografia password profili di prova (AES-256, 64 hex) ===
DB_ENCRYPTION_KEY=
